# Copy to backend/.env for local dev. In production set these as host/secret env.

# --- Required (the app refuses to start without these) ---
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=jobcity
# Use a strong random value. Production requires >= 32 characters.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# --- Environment ---
# development | production. In production the app enforces a strong JWT_SECRET
# and refuses CORS_ORIGINS="*".
APP_ENV=development
# Comma-separated allowed origins. With the nginx same-origin proxy this is the
# public frontend URL; required (not "*") in production.
CORS_ORIGINS=http://localhost:8080

# --- Ingest ---
# Disable the in-process scheduler in prod; ingest runs as a scheduled GitHub
# Action (.github/workflows/ingest.yml). Set to 0 to run ingest in-process.
INGEST_SCHEDULER_DISABLED=1
# INGEST_INTERVAL_HOURS=6
# INGEST_STARTUP_DELAY_S=30

# --- Admin bootstrap (optional) ---
# If both are set (and not the dev defaults), `python -m scripts.seed` creates
# one admin user. Leave blank to skip.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Alternative to an admin JWT for admin routes: a strong shared key (X-Admin-Key).
ADMIN_API_KEY=

# --- AI features (off by default) ---
# Requires: pip install -r requirements-ai.txt AND a key.
AI_FEATURES_ENABLED=0
EMERGENT_LLM_KEY=
